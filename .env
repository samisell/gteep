# =============================================================================
# GTEEP Website — Environment Variables
# =============================================================================
# Copy this file and fill in the values for your deployment.
# All SMTP variables below are used by the contact form email notifications.
# =============================================================================

# Site Configuration
NEXT_PUBLIC_SITE_URL=https://gteep.com
SITE_NAME=GTEEP
SITE_EMAIL=info@gteep.com

# Admin email that receives contact form notifications
# When someone submits the contact form, a notification is sent to this address
CONTACT_RECEIVER_EMAIL=info@gteep.com

# WordPress Backend
WORDPRESS_GRAPHQL_URL=https://gteep.jileadtrust.com/graphql
WORDPRESS_REST_URL=https://gteep.jileadtrust.com/wp-json
WORDPRESS_MEDIA_URL=https://gteep.jileadtrust.com/wp-content/uploads

# =============================================================================
# SMTP Email Configuration
# =============================================================================
# Fill in these values to enable email delivery for the contact form.
# Without SMTP configured, form submissions are still saved to the database
# but no email notifications are sent.
#
# Example (Gmail):
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=your-email@gmail.com
#   SMTP_PASSWORD=your-app-password
#
# Example (Outlook/Office365):
#   SMTP_HOST=smtp.office365.com
#   SMTP_PORT=587
#   SMTP_USER=your-email@outlook.com
#   SMTP_PASSWORD=your-password
#
# Example (Mailgun):
#   SMTP_HOST=smtp.mailgun.org
#   SMTP_PORT=587
#   SMTP_USER=postmaster@your-domain.mailgun.org
#   SMTP_PASSWORD=your-mailgun-password
#
# Example (Amazon SES):
#   SMTP_HOST=email-smtp.region.amazonaws.com
#   SMTP_PORT=587
#   SMTP_USER=your-ses-smtp-username
#   SMTP_PASSWORD=your-ses-smtp-password
# =============================================================================

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@gteep.com
SMTP_FROM_NAME=GTEEP

# =============================================================================
# Resend (Alternative to SMTP — https://resend.com)
# =============================================================================
# If you have a Resend API key, it takes priority over SMTP.
# =============================================================================

RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@gteep.com

# Security
NEXTAUTH_SECRET=dev-secret-change-in-production
LEAD_ENCRYPTION_KEY=dev-encryption-key-change-in-production
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=60000

# Database
DATABASE_URL=file:./custom.db

# =============================================================================
# YouTube Video Gallery
# =============================================================================
# The YouTube channel ID for the Video Gallery section of Our Outputs.
# This channel's videos will be automatically fetched and displayed.
# To find a channel ID, visit the channel page and view the page source,
# search for "channel_id=" or use https://commentpicker.com/youtube-channel-id.php
# =============================================================================
YOUTUBE_CHANNEL_ID=UCP2ZVQnqnR9bXjKyBoEDPlA

# Additional YouTube video URLs to display in the "Other Videos" section.
# Separate multiple URLs with commas.
# Examples:
#   https://www.youtube.com/watch?v=VIDEO_ID_1,https://www.youtube.com/watch?v=VIDEO_ID_2
#   https://youtu.be/VIDEO_ID_3,https://www.youtube.com/watch?v=VIDEO_ID_4
OTHER_YOUTUBE_VIDEO_URLS=
