# =============================================================================
# Vercel Postgres (Neon) Connection Strings
#
# When deploying to Vercel:
#   1. Go to Vercel Dashboard → Your Project → Storage → Create Database (Postgres)
#   2. Vercel will auto-set these environment variables
#   3. DATABASE_URL = pooled connection (for app queries, works with serverless)
#   4. DIRECT_URL   = direct connection (for Prisma migrations/schema pushes)
#
# For local development, use the same URLs from your Vercel Postgres dashboard,
# or use a local PostgreSQL instance.
# =============================================================================

# Pooled connection (uses @vercel/postgres or pgbouncer) - for app runtime
DATABASE_URL="postgresql://postgres:password@localhost:5432/gteep?schema=public"

# Direct connection (no pooling) - for Prisma schema pushes and migrations
DIRECT_URL="postgresql://postgres:password@localhost:5432/gteep?schema=public"

# =============================================================================
# WordPress GraphQL Backend
# =============================================================================
WORDPRESS_GRAPHQL_URL="https://gteep.jileadtrust.com/graphql"

# Optional: WP auth for protected content
WORDPRESS_AUTH_USER=""
WORDPRESS_AUTH_PASS=""

# =============================================================================
# YouTube Integration
# =============================================================================
YOUTUBE_CHANNEL_ID="UCP2ZVQnqnR9bXjKyBoEDPlA"

# Comma-separated YouTube video URLs for the "Other Videos" section
OTHER_YOUTUBE_VIDEO_URLS=""

# =============================================================================
# Contact Form Email (for Vercel deployment)
# =============================================================================
CONTACT_EMAIL="info@gteep.com"
